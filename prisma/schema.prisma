// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RequestStatus {
  SUBMITTED
  UNDER_REVIEW
  FOR_PICKUP
  NEEDS_REVISION
  REJECTED
  RELEASED
}
