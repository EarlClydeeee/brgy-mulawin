// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RequestStatus {
  SUBMITTED
  UNDER_REVIEW
  FOR_PICKUP
  RELEASED
}

enum DocumentType {
  BARANGAY_CLEARANCE
  CERTIFICATE_OF_RESIDENCY
  CERTIFICATE_OF_INDIGENCY
  BUSINESS_PERMIT
}

model DocumentRequest {
  id String @id @default(uuid())
  status RequestStatus @default(SUBMITTED)
  type DocumentType
  fullName String
  birthday DateTime
  address String
  purpose String
  details String?
  draftDocPath String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId String
  user User @relation(fields: [userId], references: [id])
  statusLogs RequestStatusLog[]
}

model RequestStatusLog {
  id String @id @default(uuid())
  status RequestStatus
  note String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  documentRequestId String
  documentRequest DocumentRequest @relation(fields: [documentRequestId], references: [id])
}

model User {
  id String @id
  name String
  email String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  documents DocumentRequest[]
}

model Post {
  id         String   @id @default(uuid())
  headline   String   @db.VarChar(200)
  caption    String   @db.VarChar(500)
  imageUrls  String[]
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactRateLimit {
  id          String   @id @default(uuid())
  keyHash     String
  windowStart DateTime
  expiresAt   DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([keyHash, windowStart])
  @@index([expiresAt])
}